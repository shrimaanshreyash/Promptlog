{
  "name": "@srimaanshreyas/plog",
  "version": "0.1.2",
  "description": "Permanent prompt memory, visual diffs, and human notes for AI applications.",
  "author": "Srimaan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shrimaanshreyash/Promptlog.git"
  },
  "homepage": "https://github.com/shrimaanshreyash/Promptlog#readme",
  "keywords": [
    "prompt",
    "llm",
    "ai",
    "diff",
    "version-control",
    "prompt-engineering",
    "prompt-management",
    "openai",
    "anthropic",
    "langchain"
  ],
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "plog": "dist/index.js"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc && cd ui && npm run build",
